{
	"publisher": "ylw",
	"name": "touchfish",
	"displayName": "摸鱼小工具",
	"description": "之家,快科技,财联社小工具",
	"version": "0.0.20",
	"icon": "assets/logo.png",
	"engines": {
		"vscode": "^1.67.0"
	},
	"license": "BSD-3-Clause",
  "keywords": [
    "ithome",
		"快科技",
		"it之家",
		"财联社",
		"cls"
  ],
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onView:view.newsList",
		"onView:view.kkjList",
		"onView:view.clsList"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"configuration":{
			"title": "touchfish",
			"properties": {
				"touchfish.showNewsNumber":{
					"type":"number",
					"default":10,
					"description": "每个新闻页显示多少条新闻"
				},
				"touchfish.showNewsWordNumber":{
					"type":["null","number"],
					"default":null,
					"description": "每条新闻显示多少字数"
				},
				"touchfish.refreshTime":{
					"type":"number",
					"default":30,
					"description": "多少秒刷新一次新闻"
				}
			}
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "touchfish",
					"title": "摸鱼小工具",
					"icon": "assets/training.svg"
				}
			]
		},
		"views": {
			"touchfish": [
				{
					"name": "IT之家",
					"id": "view.newsList"
				},
				{
					"name": "快科技",
					"id": "view.kkjList"
				},
				{
					"name": "财联社",
					"id": "view.clsList"
				},
				{
					"id": "view.setting",
					"name": "设置",
					"visibility": "hidden"
				}
			]
		},
		"viewsWelcome": [
			{
				"view":"view.setting",
				"contents": "[🛠打开配置页](command:touchfish.openConfigPage) \n 停止内卷,享受摸鱼!欢迎使用摸鱼小工具!😘😘😘😘😘😘😘😘"
			}			
		],
		"commands": [
			{
				"command": "itHome.refresh",
				"title": "刷新",
				"icon": {
					"dark": "assets/refresh-light.svg",
					"light": "assets/refresh.svg"
				}
			},
			{
				"command": "kkj.refresh",
				"title": "刷新",
				"icon": {
					"dark": "assets/refresh-light.svg",
					"light": "assets/refresh.svg"
				}
			},
			{
				"command": "cls.refresh",
				"title": "刷新",
				"icon": {
					"dark": "assets/refresh-light.svg",
					"light": "assets/refresh.svg"
				}
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "itHome.refresh",
					"when": "view == view.newsList",
					"group": "navigation"
				},
				{
					"command": "kkj.refresh",
					"when": "view == view.kkjList",
					"group": "navigation"
				},
				{
					"command": "cls.refresh",
					"when": "view == view.clsList",
					"group": "navigation"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "yarn run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.2.0",
		"@types/mocha": "^9.1.1",
		"@types/node": "14.x",
		"@types/vscode": "^1.67.0",
		"@typescript-eslint/eslint-plugin": "^5.21.0",
		"@typescript-eslint/parser": "^5.21.0",
		"@vscode/test-electron": "^2.1.3",
		"eslint": "^8.14.0",
		"glob": "^8.0.1",
		"mocha": "^9.2.2",
		"ts-loader": "^9.2.8",
		"typescript": "^4.6.4",
		"webpack": "^5.70.0",
		"webpack-cli": "^4.9.2"
	},
	"dependencies": {
		"axios": "^0.27.2",
		"cheerio": "1.0.0-rc.11"
	},
	"repository": {
		"type": "git",
		"url": "http://47.114.48.201:9000/yangliwei/touchfish.git"
	}
}
